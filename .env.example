# Server
PORT=8739
BASE_URL=http://localhost:8739
SESSION_SECRET=
# Number of trusted reverse proxies that append to X-Forwarded-For.
# 1 = behind a single proxy such as Caddy (rate limits key on the real client IP).
# 0 = directly exposed; ignore X-Forwarded-For and use the TCP peer.
# Setting this too high lets clients spoof their IP and bypass rate limiting.
TRUSTED_PROXY_HOPS=1

# Admin
ADMIN_USERNAME=admin
# Provide exactly one of the following. ADMIN_PASSWORD_HASH is preferred so the
# plaintext password never lives in the configuration. Generate a hash with:
#   zener hash-password            (prompts for the password)
#   zener hash-password 'secret'   (password as an argument)
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# Limits
MAX_FILE_SIZE=5368709120
ALLOWED_EXT=

# Server-blind E2E intake
# When enabled, admins can create pages whose uploads are encrypted in the
# uploader's browser before bytes leave the device. Required=true rejects
# plaintext pages and plaintext uploads.
E2E_INTAKE_ENABLED=false
E2E_INTAKE_REQUIRED=false
E2E_INTAKE_ALGORITHM=ML-KEM-1024-P384-HKDF-SHA512-AES-256-GCM

# SQLite
DB_PATH=/data/zener.db

# S3-compatible storage
S3_ENDPOINT=https://s3.eu-central-1.wasabisys.com
S3_REGION=eu-central-1
S3_BUCKET=zener
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE=false
S3_PREFIX=pages/
